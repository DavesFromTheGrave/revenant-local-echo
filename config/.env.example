# Revenant Echo Environment Variables
# Copy this file to ../.env and add your API keys

# OpenAI API key (only needed if backend.type = "openai")
# OPENAI_API_KEY=sk-...

# Ollama API key (if Ollama requires authentication)
# OLLAMA_API_KEY=...

# MegaLLM API key (needed if backend.type = "megallm")
# MEGALLM_API_KEY=sk-mega-...

# Other LLM keys as needed
# CUSTOM_LLM_KEY=...
